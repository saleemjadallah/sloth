# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sloth

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI / LLM API keys ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Scraping ────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=

# ── Zernio ──────────────────────────────────────────────────────────────
ZERNIO_API_KEY=

# ── Cloudflare R2 ──────────────────────────────────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=sloth-assets

# ── CORS ────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
